# ===========================================================================
# Ad Intelligence Platform — environment configuration
# Copy this file to `.env` and fill in values.  All values have safe defaults;
# the platform runs end-to-end even with NO Gemini key (deterministic
# heuristic analysis is used as a graceful fallback).
# ===========================================================================

# --- Database -----------------------------------------------------------------
# SQLite for the MVP.  Swap this single line to migrate (no code changes):
#   PostgreSQL : postgresql+psycopg2://user:pass@host:5432/ad_intel
#   MySQL      : mysql+pymysql://user:pass@host:3306/ad_intel
#   Oracle     : oracle+oracledb://user:pass@host:1521/?service_name=XEPDB1
DATABASE_URL=sqlite:///./ad_intelligence.db

# --- Gemini / Google GenAI ----------------------------------------------------
# Leave GEMINI_API_KEY empty to run in deterministic heuristic mode.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- Analysis engine ----------------------------------------------------------
# Number of independent samples each voting-backed agent produces for consensus.
CONSENSUS_SAMPLES=3
# Retries when an LLM returns invalid/un-repairable JSON.
LLM_MAX_RETRIES=3
# Download video bytes to a temp folder for true multimodal video analysis.
# Off by default (metadata+caption analysis is used). Temp files are always
# auto-deleted after analysis regardless of this flag.
ANALYZE_VIDEO_BINARY=false

# --- Ops ----------------------------------------------------------------------
LOG_LEVEL=INFO
